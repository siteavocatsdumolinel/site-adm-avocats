",null,{\"children\":\"Avenue de la Marne\"}],[\"$\",\"p\",null,{\"children\":\"Allée de la Marque\"}],[\"$\",\"p\",null,{\"children\":\"59290 Wasquehal\"}],[\"$\",\"a\",null,{\"href\":\"tel:0320121060\",\"className\":\"inline-block mt-2 text-[#E5493D] hover:text-white transition-colors duration-200\",\"children\":\"03 20 12 10 60\"}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-white/70 text-xs font-medium tracking-[0.2em] uppercase mb-4\",\"children\":\"Navigation\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L6\",null,{\"href\":\"/competences\",\"className\":\"text-white/50 hover:text-white transition-colors duration-200 inline-block hover:translate-x-0.5\",\"children\":\"Compétences\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L6\",null,{\"href\":\"/#equipe\",\"className\":\"text-white/50 hover:text-white transition-colors duration-200 inline-block hover:translate-x-0.5\",\"children\":\"Notre équipe\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L6\",null,{\"href\":\"/informations-et-contact\",\"className\":\"text-white/50 hover:text-white transition-colors duration-200 inline-block hover:translate-x-0.5\",\"children\":\"Infos & Contact\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-white/30 text-xs tracking-wide\",\"children\":\"© ADM 2026. Tous droits réservés.\"}],[\"$\",\"div\",null,{\"className\":\"flex items-center justify-center sm:justify-end gap-6 text-xs\",\"children\":[\"$L8\",\"$L9\"]}]]}]]}]}],\"$La\"]}]}]]}],{\"children\":[\"politique-de-confidentialite\",\"$Lb\",{\"children\":[\"__PAGE__\",\"$Lc\",{},null,false]},null,false]},null,false],\"$Ld\",false]],\"m\":\"$undefined\",\"G\":[\"$e\",[]],\"s\":false,\"S\":true}\nf:I[5996,[\"619\",\"static/chunks/619-ba102abea3e3d0e4.js\",\"27\",\"static/chunks/27-01c96e3eee302155.js\",\"177\",\"static/chunks/app/layout-cb92daaf0b0e2c1a.js\"],\"default\"]\n10:I[8434,[\"486\",\"static/chunks/486-4e48d852acd32d64.js\",\"642\",\"static/chunks/app/politique-de-confidentialite/page-bd704f2b321c241c.js\"],\"default\"]\n1b:I[4431,[],\"ViewportBoundary\"]\n1d:I[4431,[],\"MetadataBoundary\"]\n1e:\"$Sreact.suspense\"\n8:[\"$\",\"$L6\",null,{\"href\":\"/mentionslegales\",\"className\":\"text-white/30 hover:text-white/60 transition-colors duration-200\",\"children\":\"Mentions légales\"}]\n9:[\"$\",\"$L6\",null,{\"href\":\"/politique-de-confidentialite\",\"className\":\"text-white/30 hover:text-white/60 transition-colors duration-200\",\"children\":\"Politique de confidentialité\"}]\na:[\"$\",\"$Lf\",null,{}]\nb:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L4\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L5\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-white min-h-screen\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-[#f8f9f9] pt-24 pb-10\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-3xl mx-auto px-6 lg:px-8\",\"children\":[\"$\",\"$L10\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[#E5493D] text-xs tracking-[0.2em] uppercase mb-2\",\"children\":\"Informations\"}],[\"$\",\"h1\",null,{\"className\":\"text-[#313E35] text-3xl md:text-4xl font-semibold\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Politique de confidentialité & protection des données personnelles\"}]]}]}]}],[\"$\",\"div\",null,{\"className\":\"max-w-3xl mx-auto px-6 lg:px-8 py-12 lg:py-16\",\"children\":[\"$\",\"$L10\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-4 mb-10\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Dans le but de respecter la vie privée des utilisateurs de son site, ADM AVOCATS s'engage à traiter leurs données personnelles dans la plus stricte confidentialité et en totale conformité aux nouvelles réglementations européenne et française en vigueur.\"}],[\"$\",\"p\",null,{\"children\":\"La présente charte de protection est destinée à informer les utilisateurs en toute transparence des méthodes de collecte de données personnelles qu'ADM AVOCATS utilise, de l'utilisation des données ainsi collectées, des procédures de sécurité mises en place et des droits dont disposent les utilisateurs.\"}],[\"$\",\"p\",null,{\"children\":\"En utilisant le site www.adm-avocatsdumolinel.com, l'utilisateur reconnait avoir pris connaissance de la présente charte et reconnait en accepter les termes.\"}],[\"$\",\"p\",null,{\"children\":\"La présente charte est valable pour toutes les pages hébergées sur le site et pour les enregistrements de ce site. Elle n'est pas valable pour les pages hébergées par des tiers auxquelles ADM AVOCATS pourrait renvoyer, dont ADM AVOCATS n'est pas responsable des contenus et dont les politiques de confidentialité peuvent différer. ADM AVOCATS ne peut dès lors être tenu pour responsable des éventuelles données traitées sur ces sites ou par ceux-ci.\"}]]}],[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Responsable de traitement\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[\"$\",\"p\",null,{\"children\":\"ADM AVOCATS est le responsable de traitement et assume donc à ce titre la responsabilité de la collecte et de la gestion des données personnelles de ses utilisateurs conformément aux dispositions du règlement (UE) n°2016/679 du 27 avril 2016 relatif à la protection des données à caractère personnel.\"}]}]]}],[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Finalités de la collecte\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"ADM AVOCATS utilise les données de l'utilisateur afin de répondre à sa demande d'information relative aux services qu'elle propose.\"}],[\"$\",\"p\",null,{\"children\":\"En remplissant et en envoyant le formulaire, l'utilisateur consent à ce qu'ADM AVOCATS collecte et traite ses données personnelles dans le cadre précis de sa demande de renseignement et de la relation commerciale qui pourrait en découler.\"}],[\"$\",\"p\",null,{\"children\":\"La base légale du traitement est l'intérêt légitime (cf. article 6.1.f du Règlement européen sur la protection des données).\"}]]}]]}],\"$L11\",\"$L12\",\"$L13\",\"$L14\",\"$L15\",\"$L16\",\"$L17\",\"$L18\",\"$L19\"]}]}]]}],null,\"$L1a\"]}]\nd:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L1b\",null,{\"children\":\"$L1c\"}],null],[\"$\",\"$L1d\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$1e\",null,{\"fallback\":null,\"children\":\"$L1f\"}]}]}]]}]\n20:I[4431,[],\"OutletBoundary\"]\n22:I[5278,[],\"AsyncMetadataOutlet\"]\n11:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Données personnelles collectées\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"ADM AVOCATS peut collecter les données suivantes de l'utilisateur :\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-1 ml-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Les données d'identification (nom, prénom, adresse e-mail).\"}],[\"$\",\"li\",null,{\"children\":\"L'adresse IP attribuée à l'utilisateur.\"}],[\"$\",\"li\",null,{\"children\":\"Les données de localisation ou autre données relatives à la communication.\"}]]}]]}]]}]\n12:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Méthodes de collecte\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[\"$\",\"p\",null,{\"children\":\"Les données peuvent être collectées soit par l'intervention active de l'utilisateur soit automatiquement. Est une intervention active le fait pour l'utilisateur de transmettre ses données d'identification. D'autres données, telles que la date et l'heure de son accès au site, les pages consultées ou les données de localisation, sont collectées automatiquement, par le biais des serveurs consultés et des « cookies » placés sur le site. Pour en savoir plus sur l'ensemble des informations relatives aux « cookies », voir ci-dessous.\"}]}]]}]\n13:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Destinataire des données\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[\"$\",\"p\",null,{\"children\":\"Les données personnelles sont destinées à ADM AVOCATS.\"}]}]]}]\n14:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Durée de conservation des données\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"En ce qui concerne la collecte issue de l'intervention active de l'utilisateur, les données sont conservées le temps nécessaire à l'accomplissement des prestations ou le temps imposé par les différentes prescriptions légales notamment en matière fiscale, commerciale, pénale.\"}],[\"$\",\"p\",null,{\"children\":\"En ce qui concerne la collecte automatique, les données sont conservées pendant 24 mois à compter de la dernière connexion puis anonymisées et conservées à des fins historiques et statistiques pour une durée de 36 mois sauf contraintes légales particulières.\"}]]}]]}]\n15:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Cookies\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Dans le cadre de la consultation du site, des cookies de navigation peuvent être implantés dans l'ordinateur de l'utilisateur et enregistrer des informations relatives à la navigation de l'ordinateur de l'utilisateur sur le site telles que les pages consultées, la date et heure de consultation, etc. Un bandeau passant d'information est alors diffusé et permet à l'utilisateur de s'y opposer.\"}],[\"$\",\"p\",null,{\"children\":\"À tout moment, l'utilisateur a la possibilité de désactiver l'installation de cookies en adaptant en conséquence la configuration de son navigateur Internet. Si la plupart des navigateurs sont paramétrés par défaut pour accepter l'installation de cookies, l'utilisateur a la possibilité de désactiver l'utilisation des cookies en sélectionnant les paramètres appropriés de son navigateur. Toutefois, le refus des cookies et autres témoins de connexion est susceptible d'empêcher l'accès à certaines fonctionnalités, pages et/ou espaces du site, ce que l'utilisateur déclare expressément accepter.\"}]]}]]}]\n16:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Google Analytics\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"ADM AVOCATS se réserve le droit de suivre l'utilisation du Site par le visiteur en utilisant le service d'analyse de sites Internet dénommé Google Analytics fourni par la Société Google Inc. Le système Google Analytics utilise des données. Les données ainsi générées par les cookies concernant l'utilisation du site par l'utilisateur (y compris l'adresse IP de connexion) seront transmises et stockées par la Société Google Inc sur des serveurs situés aux Etats-Unis. Ces données seront utilisées dans le but d'évaluer l'utilisation du site, de compiler des rapports sur l'activité du site à destination d'ADM AVOCATS et de fournir d'autres services relatifs à l'activité du site et à l'utilisation du réseau Internet.\"}],[\"$\",\"p\",null,{\"children\":\"La Société Google Inc est susceptible de communiquer ces données à des tiers en cas d'obligation légale ou lorsque ces tiers traitent ces données pour son compte. La Société Google Inc ne recoupera pas l'adresse IP de l'utilisateur avec toute autre donnée qu'elle viendrait à détenir. L'utilisateur a la possibilité de désactiver l'utilisation de cookies en sélectionnant les paramètres appropriés de son navigateur. Cependant, une telle désactivation pourrait empêcher l'utilisation de certaines fonctionnalités, pages et/ou espaces du site, ce que l'utilisateur déclare expressément accepter.\"}]]}]]}]\n17:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Sécurité des données personnelles\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"ADM AVOCATS s'engage à tout mettre en œuvre pour assurer la confidentialité et la sécurité des données de l'utilisateur ou à faire assurer ces obligations aux sous-traitants choisis.\"}],[\"$\",\"p\",null,{\"children\":\"ADM AVOCATS assure des mesures optimales de sécurité contre la perte, l'intrusion frauduleuse, le mauvais usage et l'altération des informations qui lui sont confiées. Toutes les données reçues sur le site sont sauvegardées quotidiennement et conservées sur un support de sauvegarde.\"}]]}]]}]\n18:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Droits des utilisateurs\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"L'utilisateur dispose de façon permanente des droits suivants :\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-1 ml-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Un droit d'accès, de rectification, de suppression, un droit d'opposition et d'effacement au traitement de ses données pour motif légitime en ce qui concerne une collecte obligatoire ou sans motif lorsqu'il s'agit d'une collecte facultative.\"}],[\"$\",\"li\",null,{\"children\":\"Un droit à la limitation du traitement quand l'utilisateur s'est opposé au traitement ou lorsqu'il conteste l'exactitude des données ou lorsqu'il estime que le traitement est illicite.\"}],[\"$\",\"li\",null,{\"children\":\"Un droit à la portabilité de ses données. L'utilisateur dispose du droit de recevoir les données à caractère personnel qu'il a communiqué à ADM AVOCATS. Il peut également lui demander de transmettre ces données à un autre responsable de traitement.\"}]]}],[\"$\",\"p\",null,{\"children\":[\"Pour exercer ce droit, l'utilisateur pourra adresser sa demande accompagnée d'un justificatif d'identité par e-mail à l'adresse suivante : \",[\"$\",\"a\",null,{\"href\":\"mailto:fbeckelynck@admavocats.fr\",\"className\":\"text-[#E5493D] hover:underline\",\"children\":\"fbeckelynck@admavocats.fr\"}],\".\"]}]]}]]}]\n19:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[#313E35] text-lg font-semibold mb-3 mt-10 first:mt-0\",\"style\":{\"fontFamily\":\"var(--font-playfair)\"},\"children\":\"Mise à jour et modifications de la charte\"}],[\"$\",\"div\",null,{\"className\":\"w-10 h-[2px] bg-[#E5493D] mb-4\"}],[\"$\",\"div\",null,{\"className\":\"text-[#4d6263] text-sm leading-relaxed space-y-3\",\"children\":[\"$\",\"p\",null,{\"children\":\"ADM AVOCATS se réserve le droit de modifier ou adapter sa charte notamment, afin de respecter toute nouvelle législation et/ou réglementation applicable, les recommandations de la CNIL, les lignes directrices, les recommandations et les bonnes pratiques du Comité européen de la protection des données et les décisions des cours et tribunaux en la matière. ADM AVOCATS en informera les utilisateurs via le site.\"}]}]]}]\n1a:[\"$\",\"$L20\",null,{\"children\":[\"$L21\",[\"$\",\"$L22\",null,{\"promise\":\"$@23\"}]]}]\n1c:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n21:null\n24:I[622,[],\"IconMark\"]\n23:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"Politique de confidentialité – ADM Avocats du Molinel | ADM Avocats du Molinel\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Politique de confidentialité et protection des données personnelles du cabinet ADM – Avocats du Molinel.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"avocat,Lille,droit commercial,droit pénal,droit social,droit fiscal,Wasquehal,ADM\"}],[\"$\",\"link\",\"3\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\",\"type\":\"image/x-icon\",\"sizes\":\"16x16\"}],[\"$\",\"$L24\",\"4\",{}]],\"error\":null,\"digest\":\"$undefined\"}\n1f:\"$23:metadata\"\n"}